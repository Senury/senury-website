# Neon / Vercel Postgres connection string
# Get from: Vercel Dashboard → Storage → your database → .env tab
# DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Resend API Key for sending emails
# Get your key from: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here

# Email recipient for notifications (contact, demo & appointment forms)
# The email address where form submissions will be sent
EMAIL_RECIPIENT=contact@senury.com

# Optional: BCC address for archiving all form submissions
# Uncomment and set to receive a copy of all notifications
# EMAIL_BCC=archive@senury.com

# Demo request feature flag
# Set to "true" to enable the full demo request form with calendar
# Set to "false" to show the appointment booking page (3 date preferences)
ENABLE_DEMO_REQUEST=false

# Contact page: Show phone number
# Set to "true" to display phone contact card on contact page
# Set to "false" to hide phone number (email only)
SHOW_PHONE_NUMBER=false
